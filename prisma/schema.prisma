generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Player {
  id              String      @id @default(cuid())
  name            String
  team            String
  position        String
  sentiment       Int         @default(0)
  tweets          Int         @default(0)
  aiConfidence    Int         @default(0)
  form            String?
  imageUrl        String?
  country         String?
  shirtNumber     Int?
  weekNumber      Int         @default(0)
  season          String      @default("2024-25")
  lastUpdated     DateTime    @default(now())
  lastThemeUpdate DateTime?
  negativeTheme   String?
  positiveTheme   String?
  sentiments      Sentiment[]

  @@index([weekNumber, season])
}

model Match {
  id                 String              @id @default(cuid())
  homeTeam           String
  awayTeam           String
  homeScore          Int                 @default(0)
  awayScore          Int                 @default(0)
  status             String              @default("upcoming")
  league             String
  date               DateTime
  aggregateHome      Int                 @default(0)
  aggregateAway      Int                 @default(0)
  homeSentiment      Int                 @default(0)
  awaySentiment      Int                 @default(0)
  volatility         Float               @default(0.0)
  momentum           Float               @default(0.0)
  predictedScore     Int                 @default(0)
  psycheJSON         String?
  lastUpdated        DateTime            @default(now())
  interceptedSignals InterceptedSignal[]
  sentiments         Sentiment[]

  @@index([date])
}

model Sentiment {
  id        String   @id @default(cuid())
  score     Int
  source    String
  themes    String?
  breakdown String?
  timestamp DateTime @default(now())
  playerId  String?
  matchId   String?
  match     Match?   @relation(fields: [matchId], references: [id])
  player    Player?  @relation(fields: [playerId], references: [id])

  @@index([playerId])
  @@index([matchId])
  @@index([timestamp])
}

model InterceptedSignal {
  id        String   @id @default(cuid())
  team      String
  handle    String
  text      String
  likes     String
  retweets  String
  pulse     String
  matchId   String?
  clubId    String?
  createdAt DateTime @default(now())
  tweetId   String?
  match     Match?   @relation(fields: [matchId], references: [id])

  @@index([matchId])
  @@index([clubId])
  @@index([createdAt])
}

model DataSource {
  id          String    @id @default(cuid())
  name        String
  type        String
  url         String
  isActive    Boolean   @default(true)
  lastScraped DateTime?
  account     String?
  clubId      String?
  hashtag     String?
}

model AgentActivity {
  id        String   @id @default(cuid())
  agent     String
  action    String
  target    String
  status    String
  message   String?
  timestamp DateTime @default(now())

  @@index([timestamp])
}

model Goal {
  id           String   @id @default(cuid())
  player       String
  club         String
  opponent     String
  minute       Int
  goalType     String
  caption      String
  league       String
  matchScore   String
  matchday     String
  date         String
  tags         String
  accentColor  String
  videoUrl     String?
  thumbnailUrl String?
  videoSource  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
