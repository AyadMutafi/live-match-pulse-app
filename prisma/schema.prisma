generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/client"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Player {
  id           String      @id @default(cuid())
  name         String
  team         String
  position     String
  sentiment    Int
  tweets       Int
  aiConfidence Float
  form         String
  lastUpdated  DateTime    @updatedAt
  sentiments   Sentiment[]
}

model Match {
  id             String       @id @default(cuid())
  homeTeam       String
  awayTeam       String
  homeScore      Int
  awayScore      Int
  status         String
  league         String
  round          String?
  date           DateTime
  aggregateScore String?
  homeSentiment  Int
  awaySentiment  Int
  psycheJSON     String?
  events         String?
  lastUpdated    DateTime     @updatedAt
  sentiments     Sentiment[]
  dataSources    DataSource[]
}

model Sentiment {
  id        String   @id @default(cuid())
  playerId  String?
  matchId   String?
  score     Int
  source    String
  themes    String
  breakdown String
  timestamp DateTime @default(now())
  match     Match?   @relation(fields: [matchId], references: [id])
  player    Player?  @relation(fields: [playerId], references: [id])
}

model User {
  id           String       @id @default(cuid())
  username     String       @unique
  password     String
  role         String       @default("EDITOR") // "ADMIN" | "EDITOR"
  assignedTeam String? // e.g., "real-madrid"
  createdAt    DateTime     @default(now())
  dataSources  DataSource[]
}

model DataSource {
  id          String   @id @default(cuid())
  name        String
  type        String // 'HASHTAG' | 'ACCOUNT'
  url         String
  isActive    Boolean  @default(true)
  lastScraped DateTime @default(now())
  userId      String?
  matchId     String?
  clubId      String? // Filter for Specialists
  user        User?    @relation(fields: [userId], references: [id])
  match       Match?   @relation(fields: [matchId], references: [id])
}

model Tweet {
  id            String   @id @default(cuid())
  author        String
  handle        String
  content       String
  sentiment     Int
  likes         Int      @default(0)
  replies       Int      @default(0)
  retweets      Int      @default(0)
  url           String
  avatarBg      String
  avatarInitial String
  createdAt     DateTime @default(now())
}
