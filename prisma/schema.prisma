generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Player {
  id            String   @id @default(cuid())
  name          String
  team          String
  position      String
  sentiment     Int      @default(0)
  tweets        Int      @default(0)
  aiConfidence  Int      @default(0)
  form          String?
  lastUpdated   DateTime @default(now())
  sentiments    Sentiment[]
}

model Match {
  id             String   @id @default(cuid())
  homeTeam       String
  awayTeam       String
  homeScore      Int      @default(0)
  awayScore      Int      @default(0)
  status         String   @default("upcoming")
  league         String
  date           DateTime
  aggregateHome  Int      @default(0)
  aggregateAway  Int      @default(0)
  homeSentiment  Int      @default(0)
  awaySentiment  Int      @default(0)
  volatility     Float    @default(0.0)
  momentum       Float    @default(0.0)
  predictedScore Int      @default(0)
  psycheJSON     String?
  lastUpdated    DateTime @default(now())
  sentiments     Sentiment[]
}

model Sentiment {
  id        String   @id @default(cuid())
  score     Int
  source    String
  themes    String?
  breakdown String?
  timestamp DateTime @default(now())
  playerId  String?
  matchId   String?
  player    Player?  @relation(fields: [playerId], references: [id])
  match     Match?   @relation(fields: [matchId], references: [id])
}

model DataSource {
  id          String   @id @default(cuid())
  name        String
  type        String
  url         String
  isActive    Boolean  @default(true)
  lastScraped DateTime?
  account     String?
  hashtag     String?
  clubId      String?
}
